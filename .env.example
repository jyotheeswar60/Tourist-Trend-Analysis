# ─────────────────────────────────────────────
# Tourism Analytics Platform — Environment File
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# App settings
DEBUG=false
HOST=0.0.0.0
PORT=8050
DEFAULT_THEME=dark

# Database (SQLite is default — no setup needed)
# Switch to PostgreSQL: uncomment and fill below
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/tourism_db

# Cache
CACHE_TYPE=SimpleCache
CACHE_TIMEOUT=600
